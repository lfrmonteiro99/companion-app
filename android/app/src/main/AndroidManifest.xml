<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <!-- Used when the accessibility service is the primary observation
         channel (no MediaProjection, no mic). Keeps the foreground
         service legal under Android 14's fgServiceType enforcement. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- Partial wake lock while the capture service is running — stops
         Samsung / Doze from pausing the MediaProjection when the screen
         locks or the app goes background. Costs battery; expected for a
         continuous capture POC. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Lets the app open the per-app battery-optimization dialog so the
         user can whitelist Awareness in one tap instead of hunting
         through Settings > Apps > Battery. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!--
      Foreground-app detection. Protected permission — the user must
      grant it manually via Settings > Apps > Special app access >
      Usage access. Lint flags this as "ProtectedPermissions", which is
      expected here.
    -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <application
        android:name=".AwarenessApp"
        android:label="@string/app_name"
        android:theme="@style/Theme.Awareness"
        android:allowBackup="false"
        android:supportsRtl="true">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".HistoryActivity"
            android:exported="false"
            android:label="@string/history_title"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".LogsActivity"
            android:exported="false"
            android:label="App log"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".TraceActivity"
            android:exported="false"
            android:label="Pipeline trace"
            android:parentActivityName=".MainActivity" />

        <service
            android:name=".AwarenessService"
            android:foregroundServiceType="mediaProjection|microphone|specialUse"
            android:exported="false">
            <!-- Purpose declaration for the specialUse fg-type: our
                 capture pipeline is anchored to AwarenessAccessibility-
                 Service as the observation channel and needs a long-
                 running foreground lifetime even when MediaProjection
                 isn't active. -->
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Ongoing screen content observation via the bundled accessibility service" />
        </service>

        <!--
          Optional accessibility service. The user must enable it in
          Settings > Accessibility > Awareness. When enabled, we pull
          visible text from the focused window directly (faster and
          cleaner than OCR over MediaProjection).
        -->
        <service
            android:name=".AwarenessAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="false">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

    </application>
</manifest>
